@{
    ViewData["Title"] = "Home";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-layer-group"></i> Welcome</h1>
        <p class="subtitle">Employee Management System</p>
    </div>
</div>

<div class="container">
    <!-- Feature Cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-users fa-2x text-primary mb-2"></i>
                    <h5>Employees</h5>
                    <p class="small text-muted">Manage employee records</p>
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-primary">View</a>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-cogs fa-2x text-success mb-2"></i>
                    <h5>Properties</h5>
                    <p class="small text-muted">Define custom properties</p>
                    <a asp-controller="Property" asp-action="Index" class="btn btn-sm btn-success">Manage</a>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="fas fa-shield-alt fa-2x text-info mb-2"></i>
                    <h5>Privacy</h5>
                    <p class="small text-muted">Security & privacy info</p>
                    <a asp-controller="Home" asp-action="Privacy" class="btn btn-sm btn-outline-primary">Learn</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-3">
        <div class="col-4">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <i class="fas fa-users fa-lg"></i>
                    <div class="small">Employees</div>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <i class="fas fa-cogs fa-lg"></i>
                    <div class="small">Properties</div>
                </div>
            </div>
        </div>
        <div class="col-4">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <i class="fas fa-check-circle fa-lg"></i>
                    <div class="small">Online</div>
                </div>
            </div>
        </div>
    </div>
</div>
