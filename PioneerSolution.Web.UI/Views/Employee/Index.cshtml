@model PioneerSolution.Services.DTOs.EmployeeListViewModel

@{
    ViewData["Title"] = "Employees";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-users"></i> Employees</h1>
        <p class="subtitle">Manage your employee records</p>
    </div>
</div>

<div class="container">
    <!-- Actions -->
    <div class="row mb-3">
        <div class="col-12 d-flex flex-wrap gap-2 justify-content-between align-items-center">
            @if (Model.Employees.Any())
            {
                <span class="badge bg-primary">@Model.Employees.Count Employee(s)</span>
            }
            <div>
                <a asp-action="Create" class="btn btn-sm btn-success">
                    <i class="fas fa-plus"></i> Add
                </a>
                <a asp-controller="Property" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-cog"></i> Properties
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Employees.Any())
    {
        <div class="card">
            <div class="card-body text-center">
                <i class="fas fa-users fa-3x text-muted mb-3"></i>
                <h5>No Employees Yet</h5>
                <p class="text-muted">Click "Add" to create your first employee.</p>
                <a asp-action="Create" class="btn btn-primary">Add Employee</a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            @foreach (var def in Model.PropertyDefinitions)
                            {
                                <th>@def.Name</th>
                            }
                            <th style="width:80px">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model.Employees)
                        {
                            <tr>
                                <td><strong>@emp.Code</strong></td>
                                <td>@emp.Name</td>
                                @foreach (var def in Model.PropertyDefinitions)
                                {
                                    <td>
                                        @(emp.DynamicValues.ContainsKey(def.Id) ? emp.DynamicValues[def.Id] : "—")
                                    </td>
                                }
                                <td>
                                    <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
