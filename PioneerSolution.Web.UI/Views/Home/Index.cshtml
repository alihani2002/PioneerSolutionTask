@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="page-header animate-fade-in">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-lg-8">
                <h1><i class="fas fa-layer-group me-2"></i>Welcome to PioneerSolution</h1>
                <p class="subtitle mb-0">Employee Management System with Dynamic Properties</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- Feature Cards -->
    <div class="row g-3 g-md-4 mb-5">
        <div class="col-12 col-md-6 col-lg-4 animate-fade-in animate-delay-1">
            <div class="card-professional h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon bg-primary bg-gradient text-white rounded-circle mx-auto mb-3">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <h5 class="card-title mb-3">Employee Management</h5>
                    <p class="card-text text-muted small mb-3">
                        Manage your employee records with ease. Add, edit, and organize employee information efficiently.
                    </p>
                    <a asp-controller="Employee" asp-action="Index" class="btn btn-professional btn-primary">
                        <i class="fas fa-arrow-right me-1"></i> View Employees
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4 animate-fade-in animate-delay-2">
            <div class="card-professional h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon bg-success bg-gradient text-white rounded-circle mx-auto mb-3">
                        <i class="fas fa-cogs fa-2x"></i>
                    </div>
                    <h5 class="card-title mb-3">Custom Properties</h5>
                    <p class="card-text text-muted small mb-3">
                        Define dynamic properties for employees including strings, numbers, dates, and dropdown options.
                    </p>
                    <a asp-controller="Property" asp-action="Index" class="btn btn-professional btn-success">
                        <i class="fas fa-arrow-right me-1"></i> Manage Properties
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4 animate-fade-in animate-delay-3">
            <div class="card-professional h-100">
                <div class="card-body text-center p-4">
                    <div class="feature-icon bg-info bg-gradient text-white rounded-circle mx-auto mb-3">
                        <i class="fas fa-shield-alt fa-2x"></i>
                    </div>
                    <h5 class="card-title mb-3">Secure & Private</h5>
                    <p class="card-text text-muted small mb-3">
                        Your data is protected with industry-standard security practices and privacy measures.
                    </p>
                    <a asp-controller="Home" asp-action="Privacy" class="btn btn-professional btn-outline-primary">
                        <i class="fas fa-arrow-right me-1"></i> Learn More
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4 animate-fade-in animate-delay-1">
            <div class="card border-0 shadow-soft">
                <div class="card-body d-flex align-items-center">
                    <div class="stat-icon bg-primary bg-gradient text-white rounded me-3">
                        <i class="fas fa-users"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">Total Employees</h6>
                        <h4 class="mb-0">Manage</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 animate-fade-in animate-delay-2">
            <div class="card border-0 shadow-soft">
                <div class="card-body d-flex align-items-center">
                    <div class="stat-icon bg-success bg-gradient text-white rounded me-3">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">Custom Properties</h6>
                        <h4 class="mb-0">Dynamic</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 animate-fade-in animate-delay-3">
            <div class="card border-0 shadow-soft">
                <div class="card-body d-flex align-items-center">
                    <div class="stat-icon bg-info bg-gradient text-white rounded me-3">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0 small">System Status</h6>
                        <h4 class="mb-0">Online</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .feature-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .feature-icon i {
        font-size: 1.5rem;
    }
    
    .stat-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }
    
    /* Media query escaped for Razor */
    @@media (min-width: 768px) {
        .feature-icon {
            width: 72px;
            height: 72px;
        }
        
        .feature-icon i {
            font-size: 2rem;
        }
        
        .stat-icon {
            width: 48px;
            height: 48px;
            font-size: 1.25rem;
        }
    }
</style>
