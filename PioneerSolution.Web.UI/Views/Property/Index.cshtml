@model IEnumerable<PioneerSolution.Core.Models.PropertyDefinition>

@{
    ViewData["Title"] = "Property Definitions";
}

<!-- Page Header -->
<div class="page-header animate-fade-in">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-md-8 mb-3 mb-md-0">
                <h1><i class="fas fa-cogs me-2"></i>Property Definitions</h1>
                <p class="subtitle mb-0">Define custom properties that will appear on employee forms</p>
            </div>
            <div class="col-12 col-md-4 text-md-end">
                <a asp-action="Create" class="btn btn-professional btn-success">
                    <i class="fas fa-plus-circle me-1"></i> <span class="d-none d-sm-inline">Add New </span>Property
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">
    @if (!Model.Any())
    {
        <div class="card-professional animate-fade-in animate-delay-1">
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-cog"></i>
                </div>
                <h4>No Properties Defined</h4>
                <p>No custom properties have been defined yet. Click "Add New Property" to get started.</p>
                <a asp-action="Create" class="btn btn-professional btn-primary mt-2">
                    <i class="fas fa-plus-circle me-1"></i> Add First Property
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Action Bar -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2 animate-fade-in animate-delay-1">
            <span class="badge bg-primary bg-opacity-10 text-primary">
                <i class="fas fa-cogs me-1"></i> @Model.Count() Property Definition(s)
            </span>
            <a asp-controller="Employee" asp-action="Index" class="btn btn-professional btn-outline-secondary">
                <i class="fas fa-users me-1"></i> Go to Employees
            </a>
        </div>

        <!-- Property Table Card -->
        <div class="card-professional animate-fade-in animate-delay-2">
            <div class="table-responsive">
                <table class="table table-professional mb-0">
                    <thead>
                        <tr>
                            <th style="width: 50px;"><i class="fas fa-hashtag me-1"></i></th>
                            <th><i class="fas fa-tag me-1"></i> Property Name</th>
                            <th class="d-none d-sm-table-cell"><i class="fas fa-code me-1"></i> Type</th>
                            <th class="d-none d-sm-table-cell"><i class="fas fa-asterisk me-1"></i> Required</th>
                            <th class="text-center" style="width: 80px;"><i class="fas fa-cogs me-1"></i></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prop in Model)
                        {
                            <tr>
                                <td>
                                    <span class="text-muted">@prop.Id</span>
                                </td>
                                <td>
                                    <span class="fw-semibold">@prop.Name</span>
                                    <div class="d-sm-none mt-1">
                                        @switch (prop.Type?.ToLower())
                                        {
                                            case "string":
                                                <span class="badge badge-primary">String</span>
                                                break;
                                            case "integer":
                                                <span class="badge badge-info">Integer</span>
                                                break;
                                            case "date":
                                                <span class="badge badge-warning">Date</span>
                                                break;
                                            case "dropdown":
                                                <span class="badge badge-success">Dropdown</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@prop.Type</span>
                                                break;
                                        }
                                        @if (prop.IsRequired)
                                        {
                                            <span class="badge badge-danger ms-1">Required</span>
                                        }
                                    </div>
                                </td>
                                <td class="d-none d-sm-table-cell">
                                    @switch (prop.Type?.ToLower())
                                    {
                                        case "string":
                                            <span class="badge badge-primary">String</span>
                                            break;
                                        case "integer":
                                            <span class="badge badge-info">Integer</span>
                                            break;
                                        case "date":
                                            <span class="badge badge-warning">Date</span>
                                            break;
                                        case "dropdown":
                                            <span class="badge badge-success">Dropdown</span>
                                            break;
                                        default:
                                            <span class="badge badge-secondary">@prop.Type</span>
                                            break;
                                    }
                                </td>
                                <td class="d-none d-sm-table-cell">
                                    @if (prop.IsRequired)
                                    {
                                        <span class="badge badge-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">No</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <form asp-action="Delete" asp-route-id="@prop.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this property?');" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-professional btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
