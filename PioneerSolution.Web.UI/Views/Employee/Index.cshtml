@model PioneerSolution.Services.DTOs.EmployeeListViewModel

@{
    ViewData["Title"] = "Employees";
}

<!-- Page Header -->
<div class="page-header animate-fade-in">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-md-8 mb-3 mb-md-0">
                <h1><i class="fas fa-users me-2"></i>Employees</h1>
                <p class="subtitle mb-0">Manage your employee records and custom properties</p>
            </div>
            <div class="col-12 col-md-4 text-md-end">
                <a asp-action="Create" class="btn btn-professional btn-success">
                    <i class="fas fa-user-plus me-1"></i> <span class="d-none d-sm-inline">Add New </span>Employee
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">
    @if (!Model.Employees.Any())
    {
        <div class="card-professional animate-fade-in animate-delay-1">
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-user-friends"></i>
                </div>
                <h4>No Employees Yet</h4>
                <p>No employees have been added yet. Click "Add New Employee" to get started.</p>
                <a asp-action="Create" class="btn btn-professional btn-primary mt-2">
                    <i class="fas fa-user-plus me-1"></i> Add First Employee
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Action Bar -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 gap-2 animate-fade-in animate-delay-1">
            <span class="badge bg-primary bg-opacity-10 text-primary">
                <i class="fas fa-users me-1"></i> @Model.Employees.Count Employee(s)
            </span>
            <a asp-controller="Property" asp-action="Index" class="btn btn-professional btn-outline-secondary">
                <i class="fas fa-cogs me-1"></i> <span class="d-none d-sm-inline">Manage </span>Properties
            </a>
        </div>

        <!-- Employee Table Card -->
        <div class="card-professional animate-fade-in animate-delay-2">
            <div class="table-responsive">
                <table class="table table-professional mb-0">
                    <thead>
                        <tr>
                            <th><i class="fas fa-code me-1"></i> Code</th>
                            <th><i class="fas fa-user me-1"></i> Name</th>
                            @foreach (var def in Model.PropertyDefinitions)
                            {
                                <th class="d-none d-md-table-cell"><i class="fas fa-tag me-1"></i> @def.Name</th>
                            }
                            <th class="text-center" style="width: 100px;"><i class="fas fa-cogs me-1"></i></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in Model.Employees)
                        {
                            <tr>
                                <td>
                                    <span class="fw-semibold text-primary">@emp.Code</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-primary bg-gradient me-2 d-none d-sm-flex">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <span class="fw-medium">@emp.Name</span>
                                    </div>
                                </td>
                                @foreach (var def in Model.PropertyDefinitions)
                                {
                                    <td class="d-none d-md-table-cell">
                                        @if (emp.DynamicValues.ContainsKey(def.Id))
                                        {
                                            <span class="text-dark">@emp.DynamicValues[def.Id]</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">—</span>
                                        }
                                    </td>
                                }
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-professional btn-outline-primary" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.8rem;
        flex-shrink: 0;
    }
</style>
