@model IEnumerable<PioneerSolution.Core.Models.PropertyDefinition>

@{
    ViewData["Title"] = "Property Definitions";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-cogs"></i> Properties</h1>
        <p class="subtitle">Define custom properties for employees</p>
    </div>
</div>

<div class="container">
    <!-- Actions -->
    <div class="row mb-3">
        <div class="col-12 d-flex flex-wrap gap-2 justify-content-between align-items-center">
            @if (Model.Any())
            {
                <span class="badge bg-primary">@Model.Count() Property(ies)</span>
            }
            <div>
                <a asp-action="Create" class="btn btn-sm btn-success">
                    <i class="fas fa-plus"></i> Add
                </a>
                <a asp-controller="Employee" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-users"></i> Employees
                </a>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card">
            <div class="card-body text-center">
                <i class="fas fa-cog fa-3x text-muted mb-3"></i>
                <h5>No Properties Defined</h5>
                <p class="text-muted">Click "Add" to create your first property.</p>
                <a asp-action="Create" class="btn btn-primary">Add Property</a>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Required</th>
                            <th style="width:80px">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prop in Model)
                        {
                            <tr>
                                <td>@prop.Id</td>
                                <td><strong>@prop.Name</strong></td>
                                <td>
                                    <span class="badge bg-info">@prop.Type</span>
                                </td>
                                <td>
                                    @if (prop.IsRequired)
                                    {
                                        <span class="badge bg-danger">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@prop.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this property?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
