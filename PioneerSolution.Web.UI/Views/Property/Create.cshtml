@model PioneerSolution.Services.DTOs.AddPropertyViewModel

@{
    ViewData["Title"] = "Create Property";
}

<!-- Page Header -->
<div class="page-header animate-fade-in">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-md-8 mb-2 mb-md-0">
                <h1><i class="fas fa-plus-circle me-2"></i>Create New Property</h1>
                <p class="subtitle mb-0">Define a new custom property for employee forms</p>
            </div>
            <div class="col-12 col-md-4 text-md-end">
                <a asp-action="Index" class="btn btn-professional btn-outline-light">
                    <i class="fas fa-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="card-professional animate-fade-in animate-delay-1">
        <div class="card-body">
            <form asp-action="Create" method="post" id="propertyForm" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                <!-- Property Name -->
                <div class="mb-4">
                    <label asp-for="Name" class="form-label fw-bold">
                        <i class="fas fa-tag me-1 text-primary"></i> Property Name
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-light">
                            <i class="fas fa-pen"></i>
                        </span>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Date of Birth" required />
                    </div>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- Property Type -->
                <div class="mb-4">
                    <label class="form-label fw-bold">
                        <i class="fas fa-code me-1 text-primary"></i> Property Type
                    </label>
                    <div class="row g-2 mt-1">
                        <div class="col-6">
                            <div class="form-check-custom card h-100 p-2 border-2">
                                <input class="form-check-input ms-1" type="radio" name="Type" id="typeString" value="String" checked />
                                <label class="form-check-label fw-medium ms-2" for="typeString">
                                    <i class="fas fa-font text-info"></i> String
                                </label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check-custom card h-100 p-2 border-2">
                                <input class="form-check-input ms-1" type="radio" name="Type" id="typeInteger" value="Integer" />
                                <label class="form-check-label fw-medium ms-2" for="typeInteger">
                                    <i class="fas fa-hashtag text-info"></i> Integer
                                </label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check-custom card h-100 p-2 border-2">
                                <input class="form-check-input ms-1" type="radio" name="Type" id="typeDate" value="Date" />
                                <label class="form-check-label fw-medium ms-2" for="typeDate">
                                    <i class="fas fa-calendar-alt text-warning"></i> Date
                                </label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check-custom card h-100 p-2 border-2">
                                <input class="form-check-input ms-1" type="radio" name="Type" id="typeDropdown" value="Dropdown" />
                                <label class="form-check-label fw-medium ms-2" for="typeDropdown">
                                    <i class="fas fa-list-ul text-success"></i> Dropdown
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Required Checkbox -->
                <div class="mb-4">
                    <div class="form-check-custom card p-3 border-2 bg-light">
                        <div class="d-flex align-items-center">
                            <input asp-for="IsRequired" class="form-check-input me-3" style="width: 18px; height: 18px; flex-shrink: 0;" />
                            <label asp-for="IsRequired" class="form-check-label fw-bold mb-0">
                                <i class="fas fa-asterisk me-1 text-danger"></i> Is Required?
                            </label>
                        </div>
                        <small class="text-muted ms-4 d-block">This property must be filled when creating an employee</small>
                    </div>
                </div>

                <!-- Dropdown Choices Section -->
                <div class="mb-4" id="dropdownValuesSection" style="display: none;">
                    <div class="card border-2 border-primary bg-light">
                        <div class="card-body">
                            <label class="form-label fw-bold">
                                <i class="fas fa-list me-1 text-primary"></i> Dropdown Choices
                            </label>
                            <small class="d-block text-muted mb-3">Add the expected options for this dropdown</small>
                            
                            <div id="choicesList"></div>
                            
                            <button type="button" class="btn btn-professional btn-outline-primary btn-sm" id="addChoiceBtn">
                                <i class="fas fa-plus me-1"></i> Add Choice
                            </button>
                            
                            <input type="hidden" name="DropdownExpectedValues" id="hiddenDropdownValues" />
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex flex-column flex-sm-row justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-professional btn-secondary order-2 order-sm-1">
                        <i class="fas fa-times me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-professional btn-primary order-1 order-sm-2">
                        <i class="fas fa-save me-1"></i> Create Property
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-check-custom {
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .form-check-custom:hover {
        background-color: #f8f9fa !important;
    }
    
    .form-check-input:checked + .form-check-label {
        color: var(--accent-color);
    }
    
    .form-check-input:checked ~ .form-check-label {
        color: var(--accent-color);
    }
    
    input[type="radio"]:checked + label {
        color: var(--accent-color);
    }
</style>

@section Scripts {
    <script>
        // Toggle dropdown section based on radio selection
        document.querySelectorAll('input[name="Type"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                var section = document.getElementById('dropdownValuesSection');
                section.style.display = this.value === 'Dropdown' ? 'block' : 'none';
                
                // Update card styling
                document.querySelectorAll('.form-check-custom').forEach(function(card) {
                    card.classList.remove('border-primary');
                    card.style.backgroundColor = '';
                });
                
                if (this.value === 'Dropdown') {
                    this.closest('.form-check-custom').classList.add('border-primary');
                }
            });
        });

        // Add a new choice input row
        document.getElementById('addChoiceBtn').addEventListener('click', function () {
            addChoiceRow('');
        });

        function addChoiceRow(value) {
            var list = document.getElementById('choicesList');
            var row = document.createElement('div');
            row.className = 'd-flex align-items-center gap-2 mb-2';
            row.innerHTML =
                '<span class="input-group-text bg-white" style="padding: 0.55rem 0.75rem;"><i class="fas fa-grip-vertical text-muted"></i></span>' +
                '<input type="text" class="form-control choice-input" placeholder="Enter choice value" value="' + value + '" />' +
                '<button type="button" class="btn btn-outline-danger btn-sm remove-choice-btn" title="Remove">' +
                '<i class="fas fa-times"></i></button>';
            list.appendChild(row);

            row.querySelector('.remove-choice-btn').addEventListener('click', function () {
                row.remove();
            });
        }

        // Before submit, join all choice inputs into hidden field
        document.getElementById('propertyForm').addEventListener('submit', function () {
            var inputs = document.querySelectorAll('.choice-input');
            var values = [];
            inputs.forEach(function (input) {
                var val = input.value.trim();
                if (val) values.push(val);
            });
            document.getElementById('hiddenDropdownValues').value = values.join(',');
        });

        // Add one empty row by default if Dropdown is pre-selected
        var checkedRadio = document.querySelector('input[name="Type"]:checked');
        if (checkedRadio && checkedRadio.value === 'Dropdown') {
            document.getElementById('dropdownValuesSection').style.display = 'block';
            addChoiceRow('');
        }

        // Form validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
