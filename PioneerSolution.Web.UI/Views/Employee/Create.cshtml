@model PioneerSolution.Services.DTOs.AddEmployeeViewModel

@{
    ViewData["Title"] = "Add Employee";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-user-plus"></i> Add Employee</h1>
        <p class="subtitle">Fill in the employee details</p>
    </div>
</div>

<div class="container">
    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- Basic Info -->
                <div class="mb-3">
                    <label asp-for="Code" class="form-label">Employee Code *</label>
                    <input asp-for="Code" class="form-control" required placeholder="e.g., EMP001" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Employee Name *</label>
                    <input asp-for="Name" class="form-control" required placeholder="e.g., John Doe" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- Dynamic Properties -->
                @if (Model.PropertyDefinitions.Any())
                {
                    <hr />
                    <h5 class="mb-3">Custom Properties</h5>
                    
                    @foreach (var prop in Model.PropertyDefinitions)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                @prop.Name
                                @if (prop.IsRequired)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </label>

                            @switch (prop.Type.ToLower())
                            {
                                case "string":
                                    <input type="text" class="form-control" name="PropertyValues[@prop.Id]" 
                                           @(prop.IsRequired ? "required" : "") />
                                    break;
                                case "integer":
                                    <input type="number" class="form-control" name="PropertyValues[@prop.Id]"
                                           @(prop.IsRequired ? "required" : "") />
                                    break;
                                case "date":
                                    <input type="date" class="form-control" name="PropertyValues[@prop.Id]"
                                           @(prop.IsRequired ? "required" : "") />
                                    break;
                                case "dropdown":
                                    <select class="form-select" name="PropertyValues[@prop.Id]"
                                            @(prop.IsRequired ? "required" : ""))>
                                        <option value="">-- Select --</option>
                                        @if (!string.IsNullOrEmpty(prop.DropdownExpectedValues))
                                        {
                                            @foreach (var opt in prop.DropdownExpectedValues.Split(',', System.StringSplitOptions.TrimEntries))
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        }
                                    </select>
                                    break;
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        No properties defined. <a asp-controller="Property" asp-action="Create">Create one</a>
                    </div>
                }

                <!-- Buttons -->
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Save
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
