@model PioneerSolution.Services.DTOs.AddPropertyViewModel

@{
    ViewData["Title"] = "Create Property";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-plus-circle"></i> Create Property</h1>
        <p class="subtitle">Define a new custom property</p>
    </div>
</div>

<div class="container">
    <div class="card">
        <div class="card-body">
            <form asp-action="Create" method="post" id="propertyForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Property Name</label>
                    <input asp-for="Name" class="form-control" required placeholder="e.g., Department" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- Property Type -->
                <div class="mb-3">
                    <label class="form-label">Property Type</label>
                    <div class="d-flex flex-wrap gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Type" id="typeString" value="String" checked />
                            <label class="form-check-label" for="typeString">String</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Type" id="typeInteger" value="Integer" />
                            <label class="form-check-label" for="typeInteger">Integer</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Type" id="typeDate" value="Date" />
                            <label class="form-check-label" for="typeDate">Date</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Type" id="typeDropdown" value="Dropdown" />
                            <label class="form-check-label" for="typeDropdown">Dropdown</label>
                        </div>
                    </div>
                </div>

                <!-- Required -->
                <div class="mb-3 form-check">
                    <input asp-for="IsRequired" class="form-check-input" id="isRequired" />
                    <label asp-for="IsRequired" class="form-check-label" for="isRequired">Is Required?</label>
                </div>

                <!-- Dropdown Values -->
                <div class="mb-3" id="dropdownSection" style="display:none;">
                    <label class="form-label">Dropdown Choices</label>
                    <div id="choicesList"></div>
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="addChoiceBtn">
                        <i class="fas fa-plus"></i> Add Choice
                    </button>
                    <input type="hidden" name="DropdownExpectedValues" id="hiddenDropdownValues" />
                </div>

                <!-- Buttons -->
                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle dropdown section
        document.querySelectorAll('input[name="Type"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                document.getElementById('dropdownSection').style.display = 
                    this.value === 'Dropdown' ? 'block' : 'none';
            });
        });

        // Add choice row
        document.getElementById('addChoiceBtn').addEventListener('click', function() {
            var list = document.getElementById('choicesList');
            var row = document.createElement('div');
            row.className = 'd-flex gap-2 mb-2';
            row.innerHTML = '<input type="text" class="form-control choice-input" placeholder="Value" />' +
                '<button type="button" class="btn btn-outline-danger btn-sm remove-btn">&times;</button>';
            list.appendChild(row);
            row.querySelector('.remove-btn').addEventListener('click', function() { row.remove(); });
        });

        // Submit handler
        document.getElementById('propertyForm').addEventListener('submit', function() {
            var values = [];
            document.querySelectorAll('.choice-input').forEach(function(input) {
                if (input.value.trim()) values.push(input.value.trim());
            });
            document.getElementById('hiddenDropdownValues').value = values.join(',');
        });
    </script>
}
